{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices"
  ],
  "osvVulnerabilityAlerts": true,
  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": [
      "security"
    ]
  },
  "platformAutomerge": false,
  "prHourlyLimit": 2,
  "prConcurrentLimit": 5,
  "packageRules": [
    {
      "description": "Group npm minor updates",
      "matchManagers": ["npm"],
      "matchUpdateTypes": ["minor"],
      "groupName": "npm minor"
    },
    {
      "description": "Group npm patch updates",
      "matchManagers": ["npm"],
      "matchUpdateTypes": ["patch"],
      "groupName": "npm patch"
    },
    {
      "description": "Group Maven minor updates",
      "matchManagers": ["maven"],
      "matchUpdateTypes": ["minor"],
      "groupName": "Maven minor"
    },
    {
      "description": "Group Maven patch updates",
      "matchManagers": ["maven"],
      "matchUpdateTypes": ["patch"],
      "groupName": "Maven patch"
    },
    {
      "description": "Group all digest updates",
      "matchUpdateTypes": ["digest"],
      "groupName": "all digest"
    },
    {
      "description": "Group all pin updates",
      "matchUpdateTypes": ["pin"],
      "groupName": "all pin"
    },
    {
      "description": "Scala uses X.Y as major version; only allow 2.13.x",
      "matchPackageNames": [
        "org.scala-lang:scala-library",
        "org.scala-lang:scala-reflect"
      ],
      "versioning": "regex:^(?<major>\\d+\\.\\d+)\\.(?<minor>\\d+)$",
      "allowedVersions": "/^2\\.13\\./"
    },
    {
      "description": "Only allow stable versions for Typelevel packages",
      "matchPackageNames": [
        "org.typelevel:*"
      ],
      "allowedVersions": "/^\\d+\\.\\d+\\.\\d+$/"
    },
    {
      "description": "Group GitHub Actions major updates",
      "matchManagers": [
        "github-actions"
      ],
      "matchUpdateTypes": [
        "major"
      ],
      "groupName": "GitHub Actions (major)"
    },
    {
      "description": "Hold back ESLint ecosystem majors until plugin ecosystem catches up",
      "matchPackageNames": [
        "/^eslint/",
        "@eslint/js"
      ],
      "matchUpdateTypes": [
        "major"
      ],
      "enabled": false
    },
    {
      "description": "Group frontend build tooling major updates",
      "matchPackageNames": [
        "webpack-cli",
        "webpack-merge",
        "babel-loader",
        "@svgr/webpack"
      ],
      "matchUpdateTypes": [
        "major"
      ],
      "groupName": "frontend build tooling (major)"
    },
    {
      "description": "Hold back majors that need manual migration",
      "matchPackageNames": [
        "react",
        "react-dom",
        "react-test-renderer",
        "org.scala-lang:scala-library",
        "org.scala-lang:scala-reflect",
        "org.http4s:*"
      ],
      "matchUpdateTypes": [
        "major"
      ],
      "enabled": false
    }
  ]
}
